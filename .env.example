# ==============================================================================
# MediBridge AI Environment Variables Template (Example)
# Rename this file to '.env' and fill in your actual credentials.
# ==============================================================================

# --- DATABASE CONFIGURATION ---
# For Docker Compose, the database host is set to 'db' (the container service name)
# DATABASE_URL=postgresql://postgres:password@db:5432/medibridge
# For local running without Docker, configure your local PostgreSQL database:
DATABASE_URL=postgresql://username:password@localhost:5432/medibridge_db

# --- JWT SECURITY CONFIGURATION ---
# Generate a secure secret using: openssl rand -hex 32
SECRET_KEY=your_jwt_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120

# --- CLOUDINARY FILE STORAGE CONFIGURATION ---
# Obtain these from your Cloudinary Dashboard (https://cloudinary.com/console)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# --- GOOGLE GEMINI AI CONFIGURATION ---
# Obtain your API key from Google AI Studio (https://aistudio.google.com/)
GEMINI_API_KEY=your_gemini_api_key_here

# --- TESSERACT OCR WINDOWS CONFIGURATION ---
# (Only required if running python locally on Windows. Docker Compose handles this automatically)
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# --- FRONTEND ENVIRONMENT CONFIGURATION ---
# The URL pointing to the FastAPI backend (used by the client browser)
VITE_API_URL=http://localhost:8000
